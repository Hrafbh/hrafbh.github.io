---
import type { Lang } from "../../i18n/config";

type Project = any;
const { lang, project } = Astro.props as { lang: Lang; project: Project };

const copy = {
  en: {
    title: "ConfluRAG-SupportAgent",
    oneLiner:
      "A portfolio-ready internal support assistant based on a Confluence-backed knowledge base, combining KB-as-code, semantic retrieval, intent routing, and an interactive Streamlit demo in a realistic B2B SaaS support context.",
    role: "AI / RAG / NLP Engineering",
    contextMeta: "Personal portfolio project inspired by a real enterprise support AI use case",
    stackMeta: "Python, Confluence API, Markdown, ChromaDB, Sentence Transformers, Streamlit",
    focusMeta: "RAG pipeline, KB structuring, intent routing, support-oriented answer grounding",
    viewRepo: "View Repository",
    readme: "Read README",
    demo: "Launch Demo Locally",
    demoSoon: "Local demo setup",
    section1: "1. Context",
    section2: "2. Solution",
    section3: "3. Architecture + Tech Stack",
    section4: "4. Results / What It Demonstrates",
    section5: "5. Screenshots / Demo",
    section6: "6. Challenges & Learnings",
    section7: "7. GitHub Repo",
    contextP1:
      "This project is a portfolio-friendly reconstruction of an internal support AI assistant concept inspired by a real enterprise context I previously worked on.",
    contextP2:
      "To make the work publicly presentable without exposing internal company assets, I reframed it around a fictional B2B SaaS company called RoutePilot, focused on route planning, field execution, proof of delivery, reporting, and access administration.",
    contextP3:
      "In that setting, the assistant helps Support, Operations, and Customer Success teams resolve recurring internal requests faster by retrieving grounded procedures, troubleshooting steps, and operational guidance from a structured knowledge base.",
    solutionP1:
      "I built a support-oriented RAG system connected to a structured knowledge base maintained in Markdown and designed for synchronization with Confluence.",
    solutionP2:
      "The solution combines a KB-as-code repository for versioned support documentation, a Confluence integration workflow to simulate a live enterprise knowledge source, a vector retrieval pipeline for semantic search, an intent-routing layer to narrow retrieval, and an interactive Streamlit interface for demonstration.",
    solutionP3:
      "The assistant retrieves relevant passages, reranks them with lightweight lexical signals, extracts actionable resolution steps when possible, and can explicitly decline to answer when the evidence is too weak.",
    kbTitle: "Knowledge Base",
    kbItems: [
      "Markdown articles stored in kb/ with one page per file",
      "Stable IDs such as KB-013 and KB-024 for citations and evaluation",
      "Clear support taxonomy across onboarding, SSO/MFA, workstation, network, tooling, and incident runbooks",
      "Structured metadata to improve retrieval quality and downstream filtering",
    ],
    confluenceTitle: "Confluence Integration",
    confluenceItems: [
      "Publication workflow from Markdown KB pages to Confluence",
      "API-based extraction of Confluence pages and metadata",
      "Normalization of enterprise-style page content for indexing",
      "A realistic dual model: documentation as code plus collaborative Confluence usage",
    ],
    retrievalTitle: "Retrieval Layer",
    retrievalItems: [
      "HTML-to-text conversion from exported Confluence content",
      "Chunking with overlap before embedding generation",
      "Sentence Transformers embeddings stored in ChromaDB",
      "Intent routing, category filtering, hybrid reranking, and deduplication by page_id",
    ],
    archTitle: "System flow",
    archIntro:
      "The project is organized as an end-to-end support RAG workflow, from authored KB pages to grounded answers with citations.",
    archSteps: [
      {
        label: "Source",
        title: "KB as code",
        text: "Support pages authored in Markdown with stable IDs and structured metadata.",
      },
      {
        label: "Sync",
        title: "Confluence publish / pull",
        text: "Pages are pushed to Confluence and can also be extracted again through the API.",
      },
      {
        label: "Indexing",
        title: "Chunk + embed",
        text: "Confluence HTML is normalized, chunked, embedded, and stored in ChromaDB.",
      },
      {
        label: "Routing",
        title: "Intent + filters",
        text: "Queries are routed by intent and narrowed with category-level filtering.",
      },
      {
        label: "Ranking",
        title: "Hybrid reranking",
        text: "Vector distance is combined with keyword, title, tag, and content bonuses.",
      },
      {
        label: "Answering",
        title: "Support response",
        text: "The system returns grounded steps, cited sources, or an escalation recommendation.",
      },
    ],
    techTitle: "Main technologies",
    techTags: [
      "Python",
      "Confluence API",
      "Markdown",
      "BeautifulSoup",
      "Sentence Transformers",
      "ChromaDB",
      "JSON",
      "Streamlit",
    ],
    resultsIntro:
      "This project demonstrates a more mature support assistant design than a simple demo chatbot because it combines documentation design, retrieval engineering, and explicit evaluation.",
    resultsItems: [
      "Structure a realistic internal support knowledge base for RAG usage",
      "Combine KB-as-code with enterprise-style Confluence workflows",
      "Build a semantic retrieval pipeline with persistent vector indexing",
      "Improve precision with intent routing and lightweight reranking",
      "Handle low-confidence cases through an unknown-answer fallback and escalation logic",
      "Expose the workflow through both a CLI and a Streamlit demo",
    ],
    metricTitle: "Retrieval evaluation",
    metricNote:
      "The repository includes a curated eval set and an existing retrieval report, which gives the project a stronger engineering and validation angle.",
    metrics: [
      { label: "Hit@1", value: "75%" },
      { label: "Hit@5", value: "87.5%" },
      { label: "MRR", value: "0.775" },
      { label: "Model", value: "all-MiniLM-L6-v2" },
    ],
    demoIntro:
      "The most relevant demo format is the Streamlit interface already included in the repository.",
    demoItems: [
      "Ask support questions such as 'What should I do if PDF export fails?'",
      "Show grounded answer blocks with extracted resolution steps",
      "Display cited source pages with KB IDs",
      "Optionally surface detected intent, category filters, and top-k retrieval behavior",
    ],
    demoSetupTitle: "Local demo setup",
    demoSetup: [
      "python scripts/rag_build_index.py",
      "streamlit run scripts/streamlit_app.py",
    ],
    challengeP1:
      "One challenge was designing a fictional but credible business environment that could support realistic workflows without relying on proprietary enterprise documentation. Building the RoutePilot context made the assistant feel operational rather than generic.",
    challengeP2:
      "Another challenge was keeping retrieval useful for support scenarios where pure vector similarity is often not enough. To improve answer quality, I added intent routing, metadata filtering, reranking heuristics, and a basic fallback when the retrieved evidence is too weak.",
    learningsTitle: "Key learnings",
    learnings: [
      "Documentation quality directly shapes RAG quality",
      "Stable KB structure and metadata improve retrieval behavior",
      "Support assistants need grounded procedural answers more than conversational polish",
      "Evaluation matters in portfolio projects because it shows measured retrieval quality, not only a visual demo",
    ],
    repoText: "Public repository available on GitHub, with README, scripts, KB articles, and retrieval evaluation artifacts.",
  },
  fr: {
    title: "ConfluRAG-SupportAgent",
    oneLiner:
      "Assistant support interne pour portfolio, base sur une knowledge base reliee a Confluence, avec KB-as-code, retrieval semantique, routing par intention et demo Streamlit dans un contexte SaaS B2B realiste.",
    role: "AI / RAG / NLP Engineering",
    contextMeta: "Projet portfolio personnel inspire d'un vrai use case d'IA support en entreprise",
    stackMeta: "Python, Confluence API, Markdown, ChromaDB, Sentence Transformers, Streamlit",
    focusMeta: "Pipeline RAG, structuration de KB, intent routing, reponses support ancrees dans les sources",
    viewRepo: "View Repository",
    readme: "Read README",
    demo: "Lancer la demo en local",
    demoSoon: "Setup demo locale",
    section1: "1. Contexte",
    section2: "2. Solution",
    section3: "3. Architecture + Stack technique",
    section4: "4. Resultats / Ce que le projet démontre",
    section5: "5. Screenshots / Demo",
    section6: "6. Challenges & Learnings",
    section7: "7. GitHub Repo",
    contextP1:
      "Ce projet est une reconstruction portfolio d'un concept d'assistant support interne inspiré d'un contexte d'entreprise réel sur lequel j'avais déjà travaillé lors de mon stage de fin d'études chez Energy Pool.",
    contextP2:
      "Pour le rendre publiable sans exposer de documents internes, je l'ai reformulé autour d'une entreprise fictive B2B SaaS appelée RoutePilot, centrée sur la planification de tournées, l'exécution terrain, la preuve de livraison, le reporting et l'administration des accès.",
    contextP3:
      "Dans ce cadre, l'assistant aide les équipes Support, Operations et Customer Success à traiter plus vite les demandes récurrentes en retrouvant des procédures, des étapes de troubleshooting et de la connaissance opérationnelle de façon structurée.",
    solutionP1:
      "J'ai construit un système RAG orienté support connecté à une knowledge base structurée, maintenue en Markdown et pensée pour être synchronisée avec Confluence.",
    solutionP2:
      "La solution combine un dépôt KB-as-code pour la documentation versionnée, un workflow d'intégration Confluence pour simuler une source d'entreprise vivante, un pipeline de retrieval vectoriel, une couche de routing par intention pour réduire l'espace de recherche, et une interface Streamlit pour la démonstration.",
    solutionP3:
      "L'assistant récupère les passages pertinents, les rerank avec des signaux lexicaux simples, essaie d'extraire des resolution steps actionnables, et peut aussi refuser de répondre si les preuves sont trop faibles.",
    kbTitle: "Knowledge Base",
    kbItems: [
      "Articles Markdown dans kb/ avec 1 page par fichier",
      "IDs stables comme KB-013 et KB-024 pour les citations et l'evaluation",
      "Taxonomie support claire sur onboarding, SSO/MFA, workstation, network, tooling et runbooks d'incident",
      "Metadonnees structurees pour ameliorer le retrieval et les filtres aval",
    ],
    confluenceTitle: "Integration Confluence",
    confluenceItems: [
      "Workflow de publication depuis la KB Markdown vers Confluence",
      "Extraction des pages Confluence et des metadonnees via API",
      "Normalisation du contenu pour l'indexation",
      "Modele realiste: documentation as code plus usage collaboratif de Confluence",
    ],
    retrievalTitle: "Couche retrieval",
    retrievalItems: [
      "Conversion HTML vers texte depuis le contenu Confluence exporte",
      "Chunking avec overlap avant generation des embeddings",
      "Embeddings Sentence Transformers stockes dans ChromaDB",
      "Intent routing, filtre de categorie, reranking hybride et deduplication par page_id",
    ],
    archTitle: "Flux systeme",
    archIntro:
      "Le projet est organisé comme un workflow RAG support de bout en bout, depuis les pages KB jusqu'aux réponses ancrées avec citations.",
    archSteps: [
      {
        label: "Source",
        title: "KB as code",
        text: "Pages support rédigées en Markdown avec IDs stables et métadonnées structurées.",
      },
      {
        label: "Sync",
        title: "Confluence publish / pull",
        text: "Les pages peuvent etre publiées dans Confluence puis re-extraites via API.",
      },
      {
        label: "Indexation",
        title: "Chunk + embed",
        text: "Le HTML Confluence est normalisé, découpé, vectorisé et stocké dans ChromaDB.",
      },
      {
        label: "Routing",
        title: "Intent + filtres",
        text: "Les questions sont routées par intention puis réduites via des filtres de catégorie.",
      },
      {
        label: "Ranking",
        title: "Reranking hybride",
        text: "La distance vectorielle est combinée avec des bonus mots-clés, titre, tags et contenu.",
      },
      {
        label: "Reponse",
        title: "Support answer",
        text: "Le système renvoie des étapes de resolution sourcees ou recommande une escalation.",
      },
    ],
    techTitle: "Technologies principales",
    techTags: [
      "Python",
      "Confluence API",
      "Markdown",
      "BeautifulSoup",
      "Sentence Transformers",
      "ChromaDB",
      "JSON",
      "Streamlit",
    ],
    resultsIntro:
      "Ce projet montre un assistant support plus mature qu'un simple chatbot de démo, car il combine conception documentaire, retrieval engineering et évaluation explicite.",
    resultsItems: [
      "Structurer une vraie knowledge base support pour un usage RAG",
      "Combiner KB-as-code et workflow Confluence de style entreprise",
      "Construire un pipeline semantique avec indexation vectorielle persistante",
      "Améliorer la précision avec intent routing et reranking léger",
      "Gérer les cas de faible confiance avec unknown mode et logique d'escalade",
      "Exposer le workflow via une CLI et une démo Streamlit",
    ],
    metricTitle: "Evaluation retrieval",
    metricNote:
      "Le repo contient un eval set et un rapport retrieval déja généré, ce qui apporte une vraie dimension validation au projet.",
    metrics: [
      { label: "Hit@1", value: "75%" },
      { label: "Hit@5", value: "87.5%" },
      { label: "MRR", value: "0.775" },
      { label: "Model", value: "all-MiniLM-L6-v2" },
    ],
    demoIntro:
      "Le meilleur format de démo pour ce projet est l'interface Streamlit déja incluse dans le repository.",
    demoItems: [
      "Poser des questions de support comme 'What should I do if PDF export fails?'",
      "Montrer des blocs de réponse avec étapes de résolution extraites",
      "Afficher les pages sources citées avec leurs IDs KB",
      "Optionnellement afficher l'intent détecté, les filtres de catégorie et le comportement top-k",
    ],
    demoSetupTitle: "Setup demo locale",
    demoSetup: [
      "python scripts/rag_build_index.py",
      "streamlit run scripts/streamlit_app.py",
    ],
    challengeP1:
      "Un des principaux challenges était de construire un environnement métier fictif mais crédible, capable de supporter des workflows support réalistes sans s'appuyer sur de la documentation propriétaire. Le contexte RoutePilot rend l'assistant plus opérationnel et moins générique.",
    challengeP2:
      "Un autre challenge concernait l'utilité du retrieval en contexte support, car la simple similarité vectorielle ne suffit pas toujours. J'ai donc ajouté du routing par intention, des filtres de métadonnées, des heuristiques de reranking et un fallback basique quand les preuves sont trop faibles.",
    learningsTitle: "Principaux enseignements",
    learnings: [
      "La qualité de la documentation influence directement la qualité du RAG",
      "Une structure KB stable et des métadonnées propres améliorent le retrieval",
      "Les assistants support ont besoin de réponses procédurales ancrées plus que d'un style conversationnel",
      "L'évaluation compte aussi en portfolio, car elle montre une qualité mesurée et pas seulement une démo visuelle",
    ],
    repoText: "Dépôt public disponible sur GitHub, avec README, scripts, articles KB et artefacts d'évaluation retrieval.",
  },
} as const;

const ui = copy[lang];
const title = project.title?.[lang] ?? ui.title;
const summary = project.summary?.[lang] ?? ui.oneLiner;
const repoHref = project.links?.repo ?? "https://github.com/achrafbahich/ConfluRAG-SupportAgent";
const readmeHref = `${repoHref}#readme`;
---

<section class="detail-hero">
  <span class="eyebrow">{ui.role}</span>
  <h1>{title}</h1>
  <p>{summary}</p>


  <div class="hero-actions">
    <a class="btn-primary" href={repoHref} target="_blank" rel="noreferrer">
      {ui.viewRepo}
    </a>
    <a class="btn-secondary" href={readmeHref} target="_blank" rel="noreferrer">
      {ui.readme}
    </a>
    <span class="btn-secondary">{ui.demoSoon}</span>
  </div>
</section>

<section class="section">
  <div class="section-head">
    <div>
      <h2>{ui.section1}</h2>
    </div>
  </div>

  <article class="detail-panel">
    <p>{ui.contextP1}</p>
    <p>{ui.contextP2}</p>
    <p>{ui.contextP3}</p>
  </article>
</section>

<section class="section">
  <div class="section-head">
    <div>
      <h2>{ui.section2}</h2>
    </div>
  </div>

  <div class="detail-grid">
    <div>
      <article class="detail-panel">
        <p>{ui.solutionP1}</p>
        <p>{ui.solutionP2}</p>
        <p>{ui.solutionP3}</p>
      </article>
    </div>
    <aside>
      <article class="detail-panel">
        <h3>{ui.techTitle}</h3>
        <div class="tag-row" style="margin-top: 14px;">
          {ui.techTags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
      </article>
    </aside>
  </div>
</section>

<section class="section">
  <div class="section-head">
    <div>
      <h2>{ui.section3}</h2>
      <p>{ui.archIntro}</p>
    </div>
  </div>

  <article class="detail-panel architecture-panel">
    <div class="architecture-grid">
      {ui.archSteps.map((step) => (
        <article class="architecture-card">
          <span class="step-label">{step.label}</span>
          <h3>{step.title}</h3>
          <p>{step.text}</p>
        </article>
      ))}
    </div>
  </article>

</section>

<section class="section">
  <div class="section-head">
    <div>
      <h2>{ui.section4}</h2>
      <p>{ui.resultsIntro}</p>
    </div>
  </div>

  <div class="detail-grid">
    <div>
      <article class="detail-panel">
        <ul>
          {ui.resultsItems.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </div>
    <aside>
      <article class="detail-panel">
        <h3>{ui.metricTitle}</h3>
        <p>{ui.metricNote}</p>
        <div class="metrics-grid">
          {ui.metrics.map((metric) => (
            <div class="metric-card">
              <span>{metric.label}</span>
              <strong>{metric.value}</strong>
            </div>
          ))}
        </div>
      </article>
    </aside>
  </div>
</section>

<section class="section">
  <div class="section-head">
    <div>
      <h2>{ui.section5}</h2>
      <p>{ui.demoIntro}</p>
    </div>
  </div>

  <div class="detail-grid">
    <div>
      <article class="detail-panel">
        <ul>
          {ui.demoItems.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </div>
    <aside>
      <article class="detail-panel">
        <h3>{ui.demoSetupTitle}</h3>
        <div class="command-list">
          {ui.demoSetup.map((cmd) => <code>{cmd}</code>)}
        </div>
      </article>
    </aside>
  </div>
</section>

<section class="section">
  <div class="section-head">
    <div>
      <h2>{ui.section6}</h2>
    </div>
  </div>

  <div class="detail-grid">
    <div>
      <article class="detail-panel">
        <p>{ui.challengeP1}</p>
        <p>{ui.challengeP2}</p>
      </article>
    </div>
    <aside>
      <article class="detail-panel">
        <h3>{ui.learningsTitle}</h3>
        <ul>
          {ui.learnings.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </aside>
  </div>
</section>

<section class="section">
  <div class="section-head">
    <div>
      <h2>{ui.section7}</h2>
      <p>{ui.repoText}</p>
    </div>
  </div>

  <div class="hero-actions" style="margin-top: 0;">
    <a class="btn-primary" href={repoHref} target="_blank" rel="noreferrer">
      {ui.viewRepo}
    </a>
    <a class="btn-secondary" href={readmeHref} target="_blank" rel="noreferrer">
      {ui.readme}
    </a>
  </div>
</section>

<style>
  .meta-strip {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1.4rem;
  }

  .meta-card,
  .architecture-card,
  .metric-card {
    border: 1px solid var(--border-strong);
    border-radius: 1rem;
    background: var(--surface-strong);
    box-shadow: var(--shadow-card);
  }

  .meta-card {
    padding: 1rem 1.1rem;
  }

  .meta-card p {
    margin: 0.35rem 0 0;
    color: var(--text-soft);
  }

  .meta-label,
  .step-label {
    display: inline-flex;
    align-items: center;
    margin-bottom: 0.45rem;
    padding: 0.22rem 0.55rem;
    border-radius: 999px;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    background: var(--badge-info-bg);
    color: var(--badge-info-text);
  }

  .architecture-panel {
    margin-bottom: 18px;
    background: var(--panel-gradient-blue);
  }

  .architecture-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .architecture-card {
    padding: 1rem;
  }

  .architecture-card h3 {
    margin: 0 0 0.45rem;
    font-size: 1rem;
    color: var(--text);
  }

  .architecture-card p {
    margin: 0;
    color: var(--text-soft);
    line-height: 1.55;
  }

  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .metric-card {
    padding: 0.9rem 1rem;
  }

  .metric-card span {
    display: block;
    color: var(--muted);
    font-size: 0.88rem;
  }

  .metric-card strong {
    display: block;
    margin-top: 0.2rem;
    font-size: 1.25rem;
    color: var(--text);
  }

  .command-list {
    display: grid;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .command-list code {
    display: block;
    padding: 0.85rem 1rem;
    border-radius: 0.9rem;
    background: var(--code-bg);
    color: var(--code-text);
    font-size: 0.92rem;
    overflow-x: auto;
  }

  @media (max-width: 980px) {
    .meta-strip,
    .architecture-grid,
    .metrics-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
