---
import type { Lang } from "../../i18n/config";

type Project = any;
const { lang, project } = Astro.props as { lang: Lang; project: Project };

const copy = {
  en: {
    title: "github-issues-lakehouse-ep",
    oneLiner:
      "A public portfolio adaptation of an enterprise-style data engineering pipeline, rebuilt with GitHub Issues data from the pandas-dev/pandas repository and structured as a Bronze / Silver / Gold lakehouse.",
    context: "Personal project inspired by a real internship data engineering context",
    role: "Data Engineering / Analytics Engineering",
    stack: "Python, GitHub API, pandas, Parquet, YAML, Plotly, GitHub Pages",
    focus: "API ingestion, medallion architecture, configurable business rules, KPI marts",
    viewRepo: "View Repository",
    readme: "Read README",
    dashboard: "Open Dashboard",
    dashboardSoon: "Dashboard slot",
    section1: "1. Context",
    section2: "2. Solution",
    section3: "3. Architecture + Tech Stack",
    section4: "4. Results / What It Demonstrates",
    section5: "5. Screenshots / Demo",
    section6: "6. Challenges & Learnings",
    section7: "7. GitHub Repo",
    contextP1:
      "This project is a public portfolio adaptation of a real-world data engineering context I worked on during my internship at Energy Pool.",
    contextP2:
      "In the original professional environment, the data pipeline relied on internal operational platforms and non-public data sources that could not be shared. To make the same engineering approach visible in an open and reproducible way, I rebuilt the pipeline around GitHub Issues data from the pandas-dev/pandas repository.",
    contextP3:
      "The goal was not to reproduce the original business platform itself, but to preserve the same data engineering logic: API-based ingestion, layered raw-to-curated processing, configurable business rules, and monthly KPI generation for operational monitoring.",
    solutionP:
      "I built an end-to-end data pipeline that extracts issue data from the GitHub API, stores the raw payloads in a Bronze layer, transforms them into cleaned and enriched Silver datasets, and produces Gold KPI marts for downstream analysis and lightweight dashboarding.",
    cliTitle: "Pipeline steps",
    cliSteps: [
      "ingest for raw API extraction",
      "silver for normalization and issue classification",
      "gold for monthly KPI generation",
      "demo for quickly previewing analytical outputs",
    ],
    configNote:
      "The processing logic is configuration-driven through YAML, which makes the project easier to maintain and adapt to other repositories or label taxonomies.",
    bronzeTitle: "Bronze",
    bronzeItems: [
      "GitHub Issues API ingestion with pagination and optional time filters",
      "Timestamped JSON Lines raw storage",
      "Pull requests excluded from the issues feed",
    ],
    silverTitle: "Silver",
    silverItems: [
      "Timestamp normalization and resolution time computation",
      "Flattened labels and curated analytical columns",
      "Issue classification into ticket kind, priority tier, and component",
      "Label catalog with frequencies and descriptions",
    ],
    goldTitle: "Gold",
    goldItems: [
      "Monthly KPI tables for defect-like tickets",
      "KPIs by component and priority tier plus global aggregates",
      "Created, closed, backlog, avg / median / p90 resolution time",
      "Resolution shares within 24h, 72h, 168h, and 336h",
    ],
    techTitle: "Main technologies",
    resultsItems: [
      "Build a complete API-to-analytics pipeline",
      "Structure operational data into Bronze, Silver, and Gold layers",
      "Convert semi-structured issue data into clean analytical datasets",
      "Encode business-oriented rules in a configurable way",
      "Generate KPI marts directly usable for dashboards or reporting",
      "Expose analytical outputs through a lightweight static front-end",
    ],
    resultsNote:
      "Beyond raw extraction, the project focuses on designing a maintainable processing flow that clearly separates ingestion, transformation, and KPI generation.",
    demoIntro:
      "The interactive demo for this project is already published separately and includes the diagrams, KPI outputs, and dashboard views.",
    demoText:
      "Use the demo link below to open the dedicated project page hosted on GitHub Pages.",
    challengeP1:
      "One challenge was selecting a public data source that still reflects the complexity of operational platform data. GitHub Issues was a strong candidate because it includes labels, timestamps, states, descriptions, and enough metadata to make the transformation logic realistic.",
    challengeP2:
      "Another challenge was mapping open-source issue taxonomy to business-oriented analytical dimensions. Instead of relying on a fixed schema, I implemented configurable classification rules for issue type, priority, and component assignment.",
    learningsTitle: "Key learnings",
    learnings: [
      "Raw ingestion and analytical modeling should be clearly separated",
      "Configuration-driven rules improve maintainability",
      "Label-based operational data requires careful normalization before KPI tracking",
      "Portfolio projects are stronger when they expose architecture, modeling choices, and delivery outputs, not only code",
    ],
    repoText: "Public repository available on GitHub.",
  },
  fr: {
    title: "github-issues-lakehouse-ep",
    oneLiner:
      "Une adaptation publique d'un pipeline de data engineering inspiré d'un contexte entreprise, reconstruite à partir des GitHub Issues du dépôt pandas-dev/pandas et structurée comme un lakehouse Bronze / Silver / Gold.",
    context: "Projet personnel inspiré d'un vrai contexte de data engineering vécu en stage",
    role: "Data Engineering / Analytics Engineering",
    stack: "Python, GitHub API, pandas, Parquet, YAML, Plotly, GitHub Pages",
    focus: "Ingestion API, architecture medallion, règles métier configurables, KPI marts",
    viewRepo: "Voir le dépôt",
    readme: "Lire le README",
    dashboard: "Ouvrir le dashboard",
    dashboardSoon: "Espace dashboard",
    section1: "1. Contexte",
    section2: "2. Solution",
    section3: "3. Architecture + Stack technique",
    section4: "4. Résultats / Ce que le projet démontre",
    section5: "5. Screenshots / Démo",
    section6: "6. Difficultés & Apprentissages",
    section7: "7. Dépôt GitHub",
    contextP1:
      "Ce projet est une adaptation publique d'un contexte réel de data engineering sur lequel j'ai travaillé pendant mon stage chez Energy Pool.",
    contextP2:
      "Dans l'environnement professionnel d'origine, le pipeline s'appuyait sur des plateformes opérationnelles internes et des sources de données non publiques qui ne pouvaient pas être partagées. Pour rendre visible la même logique d'ingénierie dans un format ouvert et reproductible, j'ai reconstruit le pipeline autour des GitHub Issues du dépôt pandas-dev/pandas.",
    contextP3:
      "L'objectif n'était pas de reproduire la plateforme métier elle-même, mais de conserver la même logique data engineering : ingestion via API, traitement en couches du brut au curé, règles métier configurables et génération mensuelle des KPI pour le suivi opérationnel.",
    solutionP:
      "J'ai construit un pipeline de bout en bout qui extrait les issues depuis l'API GitHub, stocke les payloads bruts dans une couche Bronze, les transforme en jeux de données Silver nettoyés et enrichis, puis produit des marts Gold de KPI pour l'analyse aval et un dashboard léger.",
    cliTitle: "Étapes du pipeline",
    cliSteps: [
      "ingest pour l'extraction brute via API",
      "silver pour la normalisation et la classification des issues",
      "gold pour la génération mensuelle des KPI",
      "demo pour prévisualiser rapidement les sorties analytiques",
    ],
    configNote:
      "La logique de traitement est pilotée par une configuration YAML, ce qui rend le projet plus simple à maintenir et à adapter à d'autres dépôts ou taxonomies de labels.",
    bronzeTitle: "Bronze",
    bronzeItems: [
      "Ingestion depuis l'API GitHub Issues avec pagination et filtres temporels optionnels",
      "Stockage brut en JSON Lines horodaté",
      "Exclusion des pull requests de la source issues",
    ],
    silverTitle: "Silver",
    silverItems: [
      "Normalisation des timestamps et calcul du temps de résolution",
      "Aplatissement des labels et colonnes analytiques curées",
      "Classification des issues en type de ticket, niveau de priorité et composant",
      "Catalogue des labels avec fréquences et descriptions",
    ],
    goldTitle: "Gold",
    goldItems: [
      "Tables mensuelles de KPI sur les tickets de type defect-like",
      "KPI par composant et niveau de priorité, plus agrégations globales",
      "Créés, fermés, backlog, avg / median / p90 resolution time",
      "Part des tickets résolus en 24h, 72h, 168h et 336h",
    ],
    techTitle: "Technologies principales",
    resultsItems: [
      "Construire un pipeline complet de l'API jusqu'à l'analytique",
      "Structurer des données opérationnelles en couches Bronze, Silver et Gold",
      "Transformer des données semi-structurées en datasets analytiques propres",
      "Encoder des règles orientées métier de manière configurable",
      "Générer des KPI marts directement exploitables pour le dashboarding ou le reporting",
      "Exposer les sorties analytiques dans une interface statique légère",
    ],
    resultsNote:
      "Au-delà de l'extraction brute, le projet met surtout l'accent sur un flux maintenable qui sépare clairement ingestion, transformation et génération des KPI.",
    demoIntro:
      "La démo interactive du projet est déjà publiée à part et contient les diagrammes, les sorties KPI et les vues dashboard.",
    demoText:
      "Utilise le lien ci-dessous pour ouvrir la page de démo dédiée, publiée sur GitHub Pages.",
    challengeP1:
      "Un premier challenge a été de choisir une source publique capable de refléter malgré tout la complexité de données issues d'une plateforme opérationnelle. GitHub Issues s'est révélé pertinent, car les enregistrements contiennent des labels, des timestamps, des états, des descriptions et suffisamment de métadonnées pour rendre la transformation réaliste.",
    challengeP2:
      "Un autre challenge a concerné le mapping entre la taxonomie open source et des dimensions analytiques orientées métier. Au lieu de dépendre d'un schéma fixe, j'ai implémenté des règles configurables pour le type d'issue, la priorité et l'affectation des composants.",
    learningsTitle: "Principaux enseignements",
    learnings: [
      "L'ingestion brute et la modélisation analytique doivent être clairement séparées",
      "Des règles pilotées par configuration améliorent la maintenabilité",
      "Les données opérationnelles basées sur les labels nécessitent une normalisation soignée avant le suivi des KPI",
      "Un bon projet portfolio montre aussi l'architecture, la modélisation et les livrables, pas seulement le code",
    ],
    repoText: "Dépôt public disponible sur GitHub.",
  },
} as const;

const ui = copy[lang];
const title = project.title?.[lang] ?? ui.title;
const summary = project.summary?.[lang] ?? ui.oneLiner;
const repoHref = project.links?.repo ?? "https://github.com/Hrafbh/github-issues-lakehouse-ep";
const readmeHref = `${repoHref}#readme`;
const dashboardHref = project.links?.demo ?? "https://hrafbh.github.io/github-issues-lakehouse-ep/";
const techTags = ["Python 3.11", "GitHub REST API", "pandas", "PyArrow / Parquet", "YAML", "requests", "Plotly", "GitHub Pages"];
const awsDiagramSrc = "/projects/github-issues-lakehouse-ep/architecture%20solutions%20aws.png";
const medallionDiagramSrc = "/projects/github-issues-lakehouse-ep/Archeticture_Medallion.jpg";
const diagramCopy =
  lang === "fr"
    ? {
        flowTitle: "Diagramme 1. Solution AWS",
        flowAlt: "Diagramme AWS du pipeline GitHub Issues Lakehouse",
        layerTitle: "Diagramme 2. Architecture Medallion",
        layerAlt: "Diagramme medallion Bronze Silver Gold du pipeline GitHub Issues Lakehouse",
      }
    : {
        flowTitle: "Diagram 1. AWS Solution",
        flowAlt: "AWS architecture diagram for the GitHub Issues Lakehouse pipeline",
        layerTitle: "Diagram 2. Medallion Architecture",
        layerAlt: "Bronze Silver Gold medallion diagram for the GitHub Issues Lakehouse pipeline",
      };

---
<section class="detail-hero">
  <span class="eyebrow">{ui.role}</span>
  <h1>{title}</h1>
  <p>{summary}</p>

  <div class="hero-actions">
    <a class="btn-primary" href={repoHref} target="_blank" rel="noreferrer">
      {ui.viewRepo}
    </a>
    <a class="btn-secondary" href={readmeHref} target="_blank" rel="noreferrer">
      {ui.readme}
    </a>
    {dashboardHref ? (
      <a class="btn-secondary" href={dashboardHref} target="_blank" rel="noreferrer">
        {ui.dashboard}
      </a>
    ) : (
      <span class="btn-secondary">{ui.dashboardSoon}</span>
    )}
  </div>
</section>

<section class="section">
  <div class="section-head">
    <div>
      <h2>{ui.section1}</h2>
    </div>
  </div>

  <article class="detail-panel">
    <p>{ui.contextP1}</p>
    <p>{ui.contextP2}</p>
    <p>{ui.contextP3}</p>
  </article>
</section>

<section class="section">
  <div class="section-head">
    <div>
      <h2>{ui.section2}</h2>
    </div>
  </div>

  <div class="detail-grid">
    <div>
      <article class="detail-panel">
        <p>{ui.solutionP}</p>
        <p>{ui.configNote}</p>
      </article>
    </div>
    <aside>
      <article class="detail-panel">
        <h3>{ui.cliTitle}</h3>
        <ul>
          {ui.cliSteps.map((step) => <li>{step}</li>)}
        </ul>
      </article>
    </aside>
  </div>
</section>

<section class="section">
  <div class="section-head">
    <div>
      <h2>{ui.section3}</h2>
    </div>
  </div>

  <article class="detail-panel diagram-panel">
    <h3 class="diagram-title">{diagramCopy.flowTitle}</h3>
    <img class="project-diagram-image" src={awsDiagramSrc} alt={diagramCopy.flowAlt} loading="lazy" />
  </article>

  <article class="detail-panel diagram-panel">
    <h3 class="diagram-title">{diagramCopy.layerTitle}</h3>
    <img class="project-diagram-image" src={medallionDiagramSrc} alt={diagramCopy.layerAlt} loading="lazy" />
  </article>

  <div class="focus-grid">
    <article class="focus-card">
      <h3>{ui.bronzeTitle}</h3>
      <ul>
        {ui.bronzeItems.map((item) => <li>{item}</li>)}
      </ul>
    </article>

    <article class="focus-card">
      <h3>{ui.silverTitle}</h3>
      <ul>
        {ui.silverItems.map((item) => <li>{item}</li>)}
      </ul>
    </article>

    <article class="focus-card">
      <h3>{ui.goldTitle}</h3>
      <ul>
        {ui.goldItems.map((item) => <li>{item}</li>)}
      </ul>
    </article>
  </div>

  <div class="detail-grid" style="margin-top: 18px;">
    <div></div>
    <aside>
      <article class="detail-panel">
        <h3>{ui.techTitle}</h3>
        <div class="tag-row" style="margin-top: 14px;">
          {techTags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
      </article>
    </aside>
  </div>
</section>

<style>
  .diagram-panel {
    margin-bottom: 18px;
    overflow: hidden;
  }

  .diagram-title {
    margin: 0 0 1rem;
    font-size: 1.02rem;
  }

  .project-diagram-image {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 1rem;
    border: 1px solid var(--image-border);
    background: var(--image-bg);
    box-shadow: var(--shadow-image);
  }
</style>

<section class="section">
  <div class="section-head">
    <div>
      <h2>{ui.section4}</h2>
      <p>{ui.resultsNote}</p>
    </div>
  </div>

  <div class="detail-grid">
    <div>
      <article class="detail-panel">
        <ul>
          {ui.resultsItems.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </div>
  </div>
</section>

<section class="section">
  <div class="section-head">
    <div>
      <h2>{ui.section5}</h2>
      <p>{ui.demoIntro}</p>
    </div>
  </div>

  <article class="detail-panel">
    <p>{ui.demoText}</p>
    <div class="hero-actions" style="margin-top: 18px;">
      <a class="btn-primary" href={dashboardHref} target="_blank" rel="noreferrer">
        {ui.dashboard}
      </a>
    </div>
  </article>
</section>

<section class="section">
  <div class="section-head">
    <div>
      <h2>{ui.section6}</h2>
    </div>
  </div>

  <div class="detail-grid">
    <div>
      <article class="detail-panel">
        <p>{ui.challengeP1}</p>
        <p>{ui.challengeP2}</p>
      </article>
    </div>
    <aside>
      <article class="detail-panel">
        <h3>{ui.learningsTitle}</h3>
        <ul>
          {ui.learnings.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </aside>
  </div>
</section>

<section class="section">
  <div class="section-head">
    <div>
      <h2>{ui.section7}</h2>
      <p>{ui.repoText}</p>
    </div>
  </div>

  <div class="hero-actions" style="margin-top: 0;">
    <a class="btn-primary" href={repoHref} target="_blank" rel="noreferrer">
      {ui.viewRepo}
    </a>
    <a class="btn-secondary" href={readmeHref} target="_blank" rel="noreferrer">
      {ui.readme}
    </a>
    {dashboardHref ? (
      <a class="btn-secondary" href={dashboardHref} target="_blank" rel="noreferrer">
        {ui.dashboard}
      </a>
    ) : null}
  </div>
</section>

