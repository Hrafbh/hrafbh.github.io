---
<section class="detail-hero">
  <span class="eyebrow">{ui.role}</span>
  <h1>{title}</h1>
  <p>{summary}</p>

  <div class="hero-actions">
    <a class="btn-primary" href={repoHref} target="_blank" rel="noreferrer">
      {ui.viewRepo}
    </a>
    <a class="btn-secondary" href={readmeHref} target="_blank" rel="noreferrer">
      {ui.readme}
    </a>
    {dashboardHref ? (
      <a class="btn-secondary" href={dashboardHref} target="_blank" rel="noreferrer">
        {ui.dashboard}
      </a>
    ) : (
      <span class="btn-secondary">{ui.dashboardSoon}</span>
    )}
  </div>
</section>

<section class="section">
  <div class="section-head">
    <div>
      <h2>{ui.section1}</h2>
    </div>
  </div>

  <article class="detail-panel">
    <p>{ui.contextP1}</p>
    <p>{ui.contextP2}</p>
    <p>{ui.contextP3}</p>
  </article>
</section>

<section class="section">
  <div class="section-head">
    <div>
      <h2>{ui.section2}</h2>
    </div>
  </div>

  <div class="detail-grid">
    <div>
      <article class="detail-panel">
        <p>{ui.solutionP}</p>
        <p>{ui.configNote}</p>
      </article>
    </div>
    <aside>
      <article class="detail-panel">
        <h3>{ui.cliTitle}</h3>
        <ul>
          {ui.cliSteps.map((step) => <li>{step}</li>)}
        </ul>
      </article>
    </aside>
  </div>
</section>

<section class="section">
  <div class="section-head">
    <div>
      <h2>{ui.section3}</h2>
    </div>
  </div>

  <article class="detail-panel diagram-panel">
    <h3 class="diagram-title">{diagramCopy.flowTitle}</h3>
    <img class="project-diagram-image" src={awsDiagramSrc} alt={diagramCopy.flowAlt} loading="lazy" />
  </article>

  <article class="detail-panel diagram-panel">
    <h3 class="diagram-title">{diagramCopy.layerTitle}</h3>
    <img class="project-diagram-image" src={medallionDiagramSrc} alt={diagramCopy.layerAlt} loading="lazy" />
  </article>

  <div class="focus-grid">
    <article class="focus-card">
      <h3>{ui.bronzeTitle}</h3>
      <ul>
        {ui.bronzeItems.map((item) => <li>{item}</li>)}
