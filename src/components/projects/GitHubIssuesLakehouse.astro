const awsDiagramSrc = "/projects/github-issues-lakehouse%20EP/architecture%20solutions%20aws.png";
const medallionDiagramSrc = "/projects/github-issues-lakehouse%20EP/Archeticture_Medallion.jpg";
const diagramCopy =
  lang === "fr"
