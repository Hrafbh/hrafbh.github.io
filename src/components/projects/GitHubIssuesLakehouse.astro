        {ui.goldItems.map((item) => <li>{item}</li>)}
      </ul>
    </article>
  </div>

  <div class="detail-grid" style="margin-top: 18px;">
    <div></div>
    <aside>
      <article class="detail-panel">
        <h3>{ui.techTitle}</h3>
        <div class="tag-row" style="margin-top: 14px;">
          {techTags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
      </article>
    </aside>
  </div>
</section>

<style>
