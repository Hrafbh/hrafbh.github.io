const ui = copy[lang];
const title = project.title?.[lang] ?? ui.title;
const summary = project.summary?.[lang] ?? ui.oneLiner;
const repoHref = project.links?.repo ?? "https://github.com/Hrafbh/github-issues-lakehouse";
const readmeHref = `${repoHref}#readme`;
const dashboardHref = project.links?.demo ?? "https://hrafbh.github.io/github-issues-lakehouse/";
