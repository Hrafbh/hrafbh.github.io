---
import type { Lang } from "../../i18n/config";

type Project = any;
const { lang, project } = Astro.props as { lang: Lang; project: Project };

const copy = {
  en: {
    title: "GDPR Compliance Data Pipeline for Knowledge Management",
    oneLiner:
      "Design and implementation of an Azure-based data pipeline to automate GDPR-oriented anonymization for internal knowledge management platforms.",
    role: "Data Engineering Intern",
    contextLabel: "Context",
    roleLabel: "Role",
    companyLabel: "Company",
    periodLabel: "Period",
    stackLabel: "Stack",
    focusLabel: "Focus",
    contextMeta: "Internship project",
    companyMeta: "Framatome",
    periodMeta: "Apr 2024 - Aug 2024",
    stackMeta:
      "Azure Databricks, Azure Data Factory, Azure Blob Storage, Azure Key Vault, Azure DevOps, Python, Spark",
    focusMeta:
      "ETL automation, GDPR compliance, anonymization, cloud orchestration, enterprise data workflows",
    confidentiality: "Confidential project - architecture and outcomes only",
    section1: "1. Context",
    section2: "2. Mission & Solution",
    section3: "3. Architecture + Tech Stack",
    section4: "4. Results / Impact",
    section5: "5. Architecture Diagram",
    section6: "6. Challenges & Learnings",
    section7: "7. Confidentiality Note",
    contextP1:
      "During my internship at Framatome's Centrale Digital Lab, I worked on a data engineering project aimed at automating GDPR compliance within the company's Knowledge Management program.",
    contextP2:
      "The KM ecosystem relied on several internal digital platforms that contained or processed personal usage data. This created a compliance challenge: user-related data was still needed for operational monitoring and platform analytics, but retention and exposure of personal data had to stay aligned with GDPR requirements.",
    contextP3:
      "The main objective was to design an automated solution able to anonymize personal data of former employees after a defined retention period following the end of their contract, while moving away from a local script-based setup toward a centralized and more maintainable cloud environment.",
    solutionP1:
      "The project consisted in designing and implementing a set of cloud ETL pipelines to extract, transform, anonymize, and reload data used by multiple KM platforms.",
    solutionP2:
      "The key anonymization principle was to replace personal identifiers, especially usernames, with hashed placeholders such as a former employee hash. This preserved the value of historical usage data for analytics while preventing direct identification of former employees.",
    solutionP3:
      "Operationally, the solution was organized around three streams: ingestion of usage data from several KM services, enrichment with directory and leaver data, and anonymization plus reload of sanitized datasets into the analytical environment used for KM visualizations.",
    streamTitle: "Operational streams",
    streamItems: [
      "Ingestion of usage data from multiple KM data flows",
      "Enrichment with directory data and former-employee status information",
      "Anonymization and reload of sanitized datasets for downstream analytics",
    ],
    architectureIntro:
      "The solution follows a cloud-native Azure architecture built around orchestration, processing, storage, and secured secret management.",
    globalTitle: "Global architecture",
    globalSteps: [
      { tag: "Sources", title: "KM platforms", text: "Internal KM services and related usage inputs" },
      { tag: "Landing", title: "Azure Blob Storage", text: "Raw CSV files and extracted source data" },
      { tag: "Compute", title: "Azure Databricks", text: "Spark notebooks for ETL, enrichment, and anonymization" },
      { tag: "Orchestration", title: "Azure Data Factory", text: "Triggers, sequencing, and workflow automation" },
      { tag: "Secrets", title: "Azure Key Vault", text: "Secure handling of credentials and secrets" },
      { tag: "Output", title: "KM analytics", text: "Sanitized outputs reused in reporting and visualizations" },
    ],
    platformTitle: "Platform-specific ingestion flows",
    platforms: [
      {
        name: "Content platform",
        source: "Internal documentation service API",
        ingest: "API extraction or staged CSV upload",
        process: "Databricks anonymization notebook",
        output: "Sanitized content datasets for KM reporting",
      },
      {
        name: "Media platform",
        source: "Internal media service exports + usage CSV files",
        ingest: "Mixed API and file-based ingestion",
        process: "Databricks merge, enrichment, and anonymization",
        output: "Anonymized media activity datasets",
      },
      {
        name: "Discovery service",
        source: "CSV files dropped in Blob Storage",
        ingest: "Blob-based event intake",
        process: "Custom parsing + Spark transformation",
        output: "Sanitized usage datasets",
      },
    ],
    orchestrationTitle: "ADF orchestration logic",
    orchestrationText:
      "ADF was used both to monitor incoming files and to coordinate the execution sequence. Because event triggers could monitor only one file at a time, the workflow included a preliminary trigger pipeline checking whether all required inputs were present before launching the main ETL pipeline.",
    orchestrationSteps: [
      "Event detection on incoming source files",
      "Trigger pipeline validates input completeness",
      "Main pipeline launches Databricks processing steps",
      "Anonymized outputs are written to dedicated storage containers",
    ],
    techTitle: "Main technologies",
    techTags: [
      "Azure Databricks",
      "Azure Data Factory",
      "Azure Blob Storage",
      "Azure Key Vault",
      "Azure DevOps",
      "Python",
      "Spark",
      "CSV",
      "Internal APIs",
      "Secure data ingestion",
    ],
    resultsIntro:
      "The workflow was tested and validated end-to-end across several KM processing steps, making the anonymized datasets reusable inside the KM analytics environment.",
    resultsItems: [
      "Automated anonymization workflow for major KM data flows",
      "Improved GDPR alignment for internal platform analytics",
      "Sanitized historical datasets kept usable for monitoring purposes",
      "End-to-end validation across multiple internal data streams",
    ],
    impactTitle: "Reporting impact example",
    impactBefore: "Before anonymization, reporting visualizations only reflected current employees.",
    impactAfter:
      "After anonymization, the dashboard included both current and former employee contributions without exposing personal identities, improving the completeness of historical monitoring.",
    visualsIntro:
      "This project is best presented through diagrams rather than code screenshots. The most valuable portfolio assets are architecture views, platform flows, orchestration logic, and before/after reporting visuals.",
    visualsItems: [
      "Simplified global architecture of the Azure pipeline",
      "Dedicated diagrams for key ingestion and anonymization flows",
      "Simplified ADF trigger and main pipeline orchestration view",
      "Before / after analytics comparison showing the impact of anonymization",
    ],
    challenges: [
      {
        title: "Enterprise network constraints",
        text:
          "Some sources and the original GitLab repository were inside Framatome's internal network, which limited direct access from Databricks. Workarounds included moving the repository to Azure DevOps and temporarily extracting data locally before uploading CSV files to Blob Storage.",
      },
      {
        title: "Messy CSV parsing",
        text:
          "Some usage logs could contain arbitrary free text, and other datasets included comma-separated content fields, which interfered with standard delimiter-based parsing. The solution combined Spark multiline and special-character handling with a custom parsing function for the affected files.",
      },
      {
        title: "Workflow triggering",
        text:
          "ADF event triggers could not watch all required files at once, so the workflow needed an additional control layer to verify file readiness before launching the main ETL sequence.",
      },
    ],
    learningsTitle: "Key learnings",
    learnings: [
      "Enterprise data engineering often means bridging cloud services with constrained internal systems",
      "Compliance projects still require careful product thinking so analytics remains useful after anonymization",
      "Messy flat files and orchestration edge cases are part of real-world ETL work, not exceptions",
      "Architecture diagrams can communicate delivery quality better than code screenshots when the project is confidential",
    ],
    confidentialityP1:
      "This project is presented in a portfolio-friendly format based on an internship report. Internal code, company assets, and operational details are not publicly shared.",
    confidentialityP2:
      "Diagrams and explanations are intentionally limited to high-level architectural and functional aspects.",
  },
  fr: {
    title: "Pipeline de conformité RGPD",
    oneLiner:
      "Conception et mise en place d'un pipeline de données sur Azure pour automatiser l'anonymisation orientée RGPD sur des plateformes internes de knowledge management.",
    role: "Stagiaire Data Engineering",
    contextLabel: "Contexte",
    roleLabel: "Rôle",
    companyLabel: "Entreprise",
    periodLabel: "Période",
    stackLabel: "Stack",
    focusLabel: "Focus",
    contextMeta: "Projet de stage",
    companyMeta: "Framatome",
    periodMeta: "Avr 2024 - Août 2024",
    stackMeta:
      "Azure Databricks, Azure Data Factory, Azure Blob Storage, Azure Key Vault, Azure DevOps, Python, Spark",
    focusMeta:
      "Automatisation ETL, conformité RGPD, anonymisation, orchestration cloud, workflows data en entreprise",
    confidentiality: "Projet confidentiel - architecture et résultats uniquement",
    section1: "1. Contexte",
    section2: "2. Mission & Solution",
    section3: "3. Architecture + Stack technique",
    section4: "4. Résultats / Impact",
    section5: "5. Diagramme d'architecture",
    section6: "6. Challenges & Learnings",
    section7: "7. Note de confidentialité",
    contextP1:
      "Pendant mon stage au Centrale Digital Lab chez Framatome, j'ai travaillé sur un projet de data engineering visant à automatiser la conformité RGPD au sein du programme de Knowledge Management de l'entreprise.",
    contextP2:
      "L'écosystème KM s'appuyait sur plusieurs plateformes digitales internes qui contenaient ou traitaient des données d'usage personnelles. Cela posait un enjeu de conformité: ces données restaient utiles pour le monitoring opérationnel et l'analytique plateforme, mais leur rétention et leur exposition devaient rester alignées avec les exigences RGPD.",
    contextP3:
      "L'objectif principal était de concevoir une solution automatisée capable d'anonymiser les données personnelles d'anciens employés après une période de rétention définie suivant la fin de leur contrat, tout en remplaçant une logique locale basée sur des scripts par un environnement cloud centralisé et plus maintenable.",
    solutionP1:
      "Le projet a consisté à concevoir et implémenter un ensemble de pipelines ETL cloud pour extraire, transformer, anonymiser et recharger les données utilisées par plusieurs plateformes KM.",
    solutionP2:
      "Le principe central d'anonymisation était de remplacer les identifiants personnels, notamment les usernames, par des placeholders hash tels qu'un former employee hash. Cela permettait de conserver la valeur analytique des historiques d'usage tout en empêchant l'identification directe d'anciens employés.",
    solutionP3:
      "Sur le plan opérationnel, la solution s'organisait autour de trois flux: ingestion des données d'usage depuis plusieurs services KM, enrichissement avec les données annuaire et le statut de départ, puis anonymisation et rechargement des datasets nettoyés dans l'environnement analytique utilisé pour les visualisations KM.",
    streamTitle: "Flux opérationnels",
    streamItems: [
      "Ingestion des données d'usage depuis plusieurs flux KM",
      "Enrichissement avec les données annuaire et les informations sur les anciens employés",
      "Anonymisation puis rechargement de datasets sanitizés pour l'analytique aval",
    ],
    architectureIntro:
      "La solution suit une architecture Azure cloud-native articulée autour de l'orchestration, du processing, du stockage et de la gestion sécurisée des secrets.",
    globalTitle: "Architecture globale",
    globalSteps: [
      { tag: "Sources", title: "Plateformes KM", text: "Services KM internes et leurs données d'usage" },
      { tag: "Landing", title: "Azure Blob Storage", text: "Fichiers CSV bruts et données sources extraites" },
      { tag: "Compute", title: "Azure Databricks", text: "Notebooks Spark pour ETL, enrichissement et anonymisation" },
      { tag: "Orchestration", title: "Azure Data Factory", text: "Triggers, sequencing et automatisation" },
      { tag: "Secrets", title: "Azure Key Vault", text: "Gestion sécurisée des credentials et secrets" },
      { tag: "Output", title: "Analytics KM", text: "Sorties anonymisées réutilisées dans le reporting" },
    ],
    platformTitle: "Flux d'ingestion par plateforme",
    platforms: [
      {
        name: "Plateforme documentaire",
        source: "API interne de documentation",
        ingest: "Extraction API ou upload de CSV préparés",
        process: "Notebook Databricks d'anonymisation",
        output: "Datasets documentaires sanitizés pour le reporting KM",
      },
      {
        name: "Plateforme média",
        source: "Exports d'un service média interne + fichiers CSV d'usage",
        ingest: "Ingestion mixte API et fichiers",
        process: "Merge, enrichissement et anonymisation dans Databricks",
        output: "Datasets d'activité média anonymisés",
      },
      {
        name: "Service de recherche et découverte",
        source: "Fichiers CSV déposés dans Blob Storage",
        ingest: "Intake événementiel depuis Blob",
        process: "Parsing custom + transformation Spark",
        output: "Datasets d'usage sanitizés",
      },
    ],
    orchestrationTitle: "Logique d'orchestration ADF",
    orchestrationText:
      "ADF était utilisé à la fois pour surveiller les fichiers entrants et pour coordonner la séquence d'exécution. Comme les event triggers ne pouvaient surveiller qu'un fichier à la fois, le workflow comprenait un trigger pipeline préliminaire chargé de vérifier que tous les inputs requis étaient présents avant de lancer le pipeline ETL principal.",
    orchestrationSteps: [
      "Détection événementielle des fichiers sources entrants",
      "Le trigger pipeline vérifie la complétude des inputs",
      "Le pipeline principal lance les traitements Databricks",
      "Les sorties anonymisées sont écrites dans des containers dédiés",
    ],
    techTitle: "Technologies principales",
    techTags: [
      "Azure Databricks",
      "Azure Data Factory",
      "Azure Blob Storage",
      "Azure Key Vault",
      "Azure DevOps",
      "Python",
      "Spark",
      "CSV",
      "APIs internes",
      "Ingestion sécurisée",
    ],
    resultsIntro:
      "Le workflow a été testé et validé de bout en bout sur plusieurs traitements KM, ce qui a permis de réutiliser les datasets anonymisés dans l'environnement analytique KM.",
    resultsItems: [
      "Automatisation de l'anonymisation pour les principaux flux de données KM",
      "Meilleur alignement RGPD pour l'analytique des plateformes internes",
      "Conservation de jeux historiques exploitables pour le monitoring",
      "Validation end-to-end sur plusieurs flux internes",
    ],
    impactTitle: "Exemple d'impact sur le reporting",
    impactBefore: "Avant anonymisation, certaines visualisations de reporting ne reflétaient que les employés actuels.",
    impactAfter:
      "Après anonymisation, le dashboard intégrait aussi les contributions des anciens employés sans exposer leurs identités, ce qui améliorait la complétude du suivi historique.",
    visualsIntro:
      "Ce projet se présente mieux avec des diagrammes qu'avec des captures de code. Les assets les plus utiles pour le portfolio sont les vues d'architecture, les flux par plateforme, la logique d'orchestration et les comparaisons avant/après sur le reporting.",
    visualsItems: [
      "Architecture globale simplifiée du pipeline Azure",
      "Diagrammes dédiés aux principaux flux d'ingestion et d'anonymisation",
      "Vue simplifiée du trigger ADF et du pipeline principal",
      "Comparaison analytique avant / après montrant l'impact de l'anonymisation",
    ],
    challenges: [
      {
        title: "Contraintes réseau entreprise",
        text:
          "Certaines sources et le dépôt GitLab d'origine étaient situés dans le réseau interne Framatome, ce qui limitait l'accès direct depuis Databricks. Les contournements ont notamment consisté à déplacer le dépôt vers Azure DevOps et à extraire temporairement certaines données en local avant upload vers Blob Storage.",
      },
      {
        title: "Parsing CSV complexe",
        text:
          "Certains logs d'usage pouvaient contenir du texte arbitraire dans des champs libres, et d'autres datasets comportaient des listes de contenus séparées par des virgules, ce qui perturbait un parsing standard. La solution a combiné la configuration Spark pour les cas multiline et caractères spéciaux avec une fonction de parsing custom pour les fichiers concernés.",
      },
      {
        title: "Déclenchement du workflow",
        text:
          "Les event triggers ADF ne pouvaient pas surveiller l'ensemble des fichiers requis en même temps. Le workflow a donc nécessité une couche de contrôle supplémentaire pour vérifier la disponibilité des fichiers avant de lancer la séquence ETL principale.",
      },
    ],
    learningsTitle: "Principaux enseignements",
    learnings: [
      "Le data engineering en entreprise consiste souvent à faire le pont entre services cloud et systèmes internes contraints",
      "Les projets de conformité demandent aussi une vraie logique produit pour garder une analytique utile après anonymisation",
      "Les flat files imparfaits et les cas limites d'orchestration font partie du vrai travail ETL",
      "Quand un projet est confidentiel, de bons diagrammes communiquent souvent mieux la valeur que des captures de code",
    ],
    confidentialityP1:
      "Ce projet est présenté dans un format portfolio à partir d'un rapport de stage. Le code interne, les assets entreprise et les détails opérationnels ne sont pas partagés publiquement.",
    confidentialityP2:
      "Les diagrammes et explications sont volontairement limités à des aspects architecturaux et fonctionnels de haut niveau.",
  },
} as const;

const ui = copy[lang];
const title = project.title?.[lang] ?? ui.title;
const summary = project.summary?.[lang] ?? ui.oneLiner;
const companyLogo = "/projects/framatome/logo_framatome.png";
const architectureDiagram = "/projects/framatome/Architecture%20anonymisation.png";
const adfWorkflowDiagram = "/projects/framatome/Workflow%20ADF.png";
const techLogos = [
  { name: "Azure Databricks", src: "/projects/framatome/Databricks.png" },
  { name: "Azure Data Factory", src: "/projects/framatome/Azure%20Data%20Factory.png" },
  { name: "Azure Key Vault", src: "/projects/framatome/azure-key-vault.png" },
  { name: "Azure DevOps", src: "/projects/framatome/Azure%20Devops.png" },
];
---

<section class="detail-hero framatome-hero">
  <span class="eyebrow">{ui.role}</span>
  <div class="hero-brand">
    <img src={companyLogo} alt="Framatome logo" loading="lazy" />
  </div>
  <h1>{title}</h1>
  <p>{summary}</p>


  <div class="hero-actions">
    <span class="btn-secondary">{ui.confidentiality}</span>
  </div>
</section>

<section class="section">
  <div class="section-head">
    <div>
      <h2>{ui.section1}</h2>
    </div>
  </div>

  <article class="detail-panel">
    <p>{ui.contextP1}</p>
    <p>{ui.contextP2}</p>
    <p>{ui.contextP3}</p>
  </article>
</section>

<section class="section">
  <div class="section-head">
    <div>
      <h2>{ui.section2}</h2>
    </div>
  </div>

  <div class="detail-grid">
    <div>
      <article class="detail-panel">
        <p>{ui.solutionP1}</p>
        <p>{ui.solutionP2}</p>
        <p>{ui.solutionP3}</p>
      </article>
    </div>
    <aside>
      <article class="detail-panel">
        <h3>{ui.streamTitle}</h3>
        <ul>
          {ui.streamItems.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </aside>
  </div>
</section>

<section class="section">
  <div class="section-head">
    <div>
      <h2>{ui.section3}</h2>
      <p>{ui.architectureIntro}</p>
    </div>
  </div>

  <div class="detail-grid" style="margin-top: 18px;">
    <div>
      <article class="detail-panel">
        <h3>{ui.globalTitle}</h3>
        <p>{ui.orchestrationText}</p>
      </article>
    </div>
    <aside>
      <article class="detail-panel">
        <h3>{ui.techTitle}</h3>
        <div class="logo-grid">
          {techLogos.map((tech) => (
            <div class="logo-card">
              <img src={tech.src} alt={`${tech.name} logo`} loading="lazy" />
              <span>{tech.name}</span>
            </div>
          ))}
        </div>
        <div class="tag-row" style="margin-top: 14px;">
          {ui.techTags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
      </article>
    </aside>
  </div>
</section>

<section class="section">
  <div class="section-head">
    <div>
      <h2>{ui.section4}</h2>
      <p>{ui.resultsIntro}</p>
    </div>
  </div>

  <div class="detail-grid">
    <div>
      <article class="detail-panel">
        <ul>
          {ui.resultsItems.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </div>
    <aside>
      <article class="detail-panel impact-panel">
        <h3>{ui.impactTitle}</h3>
        <div class="impact-compare">
          <div class="impact-card before">
            <span>Before</span>
            <p>{ui.impactBefore}</p>
          </div>
          <div class="impact-arrow" aria-hidden="true">-&gt;</div>
          <div class="impact-card after">
            <span>After</span>
            <p>{ui.impactAfter}</p>
          </div>
        </div>
      </article>
    </aside>
  </div>
</section>

<section class="section">
  <div class="section-head">
    <div>
      <h2>{ui.section5}</h2>
    </div>
  </div>

  <article class="detail-panel diagram-image-panel">
    <h3 class="diagram-title">{ui.globalTitle}</h3>
    <img
      class="project-diagram"
      src={architectureDiagram}
      alt="Framatome GDPR anonymization architecture diagram showing source data, ingestion, processing, storage, and analytical outputs."
      loading="lazy"
    />
  </article>

</section>

<section class="section">
  <div class="section-head">
    <div>
      <h2>{ui.section6}</h2>
    </div>
  </div>

  <div class="challenge-grid">
    {ui.challenges.map((challenge) => (
      <article class="detail-panel challenge-card">
        <h3>{challenge.title}</h3>
        <p>{challenge.text}</p>
      </article>
    ))}
  </div>

  <div class="detail-grid" style="margin-top: 18px;">
    <div></div>
    <aside>
      <article class="detail-panel">
        <h3>{ui.learningsTitle}</h3>
        <ul>
          {ui.learnings.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </aside>
  </div>
</section>


<style>
  .framatome-hero {
    background: var(--framatome-hero-bg);
  }

  .hero-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    margin: 0.75rem 0 0.35rem;
    padding: 0.55rem 0.9rem;
    border-radius: 999px;
    background: var(--glass-strong);
    border: 1px solid var(--border-strong);
    box-shadow: var(--shadow-card);
  }

  .hero-brand img {
    display: block;
    height: 22px;
    width: auto;
  }

  .hero-brand span {
    color: var(--text);
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .meta-strip {
    display: grid;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .meta-strip-wide {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .meta-card,
  .challenge-card,
  .impact-card {
    border: 1px solid var(--border-strong);
    border-radius: 1rem;
    background: var(--surface-strong);
    box-shadow: var(--shadow-card);
  }

  .meta-card {
    padding: 1rem 1.1rem;
  }

  .meta-card p {
    margin: 0.35rem 0 0;
    color: var(--text-soft);
  }

  .meta-label,
  .impact-card span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.24rem 0.58rem;
    border-radius: 999px;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .meta-label {
    background: var(--badge-info-bg);
    color: var(--badge-info-text);
  }

  .diagram-title {
    margin: 0 0 1rem;
    color: var(--text);
  }

  .diagram-image-panel,
  .impact-panel {
    background: var(--panel-gradient-blue);
  }

  .challenge-card h3 {
    margin: 0.6rem 0 0.45rem;
    font-size: 1rem;
    color: var(--text);
  }

  .challenge-card p {
    margin: 0;
    color: var(--text-soft);
    line-height: 1.55;
  }

  .impact-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--muted);
    font-weight: 700;
    font-size: 1.2rem;
  }

  .challenge-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .challenge-card {
    padding: 1rem;
  }

  .logo-grid {
    display: grid;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .logo-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .logo-card {
    display: grid;
    justify-items: center;
    gap: 0.55rem;
    padding: 0.9rem 0.75rem;
    border-radius: 0.95rem;
    border: 1px solid var(--border-strong);
    background: var(--surface-muted);
    text-align: center;
  }

  .logo-card img {
    display: block;
    max-width: 100%;
    height: 32px;
    object-fit: contain;
  }

