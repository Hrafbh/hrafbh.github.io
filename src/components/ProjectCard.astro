---
import type { Lang } from "../i18n/config";

type LocalizedText = {
  en: string;
  fr: string;
};

type ProjectCardProps = {
  project: {
    slug: string;
    title: LocalizedText;
    summary: LocalizedText;
    date?: string;
    status?: "live" | "wip";
    links?: {
      repo?: string;
      demo?: string;
    };
    category?: Partial<Record<Lang, string>>;
    tags?: string[];
    stack?: string[];
    tech?: string[];
    skills?: string[];
    mainTech?: string[];
  };
  lang?: Lang;
};

const { project, lang = "en" } = Astro.props as ProjectCardProps;

const title = project.title?.[lang] ?? project.title.en ?? project.slug;
const summary = project.summary?.[lang] ?? project.summary.en ?? "";
const skills = Array.isArray(project.skills) ? project.skills : [];
const mainTech =
  Array.isArray(project.mainTech) ? project.mainTech :
  Array.isArray(project.tags) ? project.tags :
  Array.isArray(project.stack) ? project.stack :
  Array.isArray(project.tech) ? project.tech :
  [];
const fallbackTags =
  Array.isArray(project.tags) ? project.tags :
  Array.isArray(project.stack) ? project.stack :
  Array.isArray(project.tech) ? project.tech :
  [];
const visibleSkills = skills.slice(0, 4);
const visibleMainTech = mainTech.slice(0, 4);
const combinedTags = [...new Set([...visibleSkills, ...visibleMainTech])];
const visibleTags = combinedTags.length > 0 ? combinedTags : fallbackTags.slice(0, 6);

const category =
  project.category?.[lang] ??
  project.category?.en ??
  (project.slug.includes("rag")
    ? (lang === "fr" ? "IA / RAG" : "AI / RAG")
    : "Data Engineering");

const projectHref = `/${lang}/projects/${project.slug}/`;
const companyLogoBySlug = {
  "framatome-data-engineering-project": {
    src: "/projects/framatome/logo_framatome.png",
    alt: "Framatome logo",
    height: 18,
  },
  "github-issues-lakehouse-ep": {
    src: "/projects/github-issues-lakehouse-ep/energy%20pool%20logo.png",
    alt: "Energy Pool logo",
    height: 22,
  },
  "confluence-rag-chatbot": {
    src: "/projects/confluence-rag-ep/energy%20pool%20logo.png",
    alt: "Energy Pool logo",
    height: 22,
  },
  "academic-data-science-project": {
    src: "/projects/engie-challenge/engie.png",
    alt: "ENGIE logo",
    height: 22,
  },
} as const;

const companyLogo =
  project.slug in companyLogoBySlug
    ? companyLogoBySlug[project.slug as keyof typeof companyLogoBySlug]
    : null;
---
<article class="project-card">
  <div class="project-meta">
    <span class="project-type">{category}</span>
    {project.date ? <span class="project-date">{project.date}</span> : null}
  </div>

  {companyLogo ? (
    <div class="project-company-badge" style={`--company-logo-height: ${companyLogo.height}px;`}>
      <img src={companyLogo.src} alt={companyLogo.alt} loading="lazy" />
    </div>
  ) : null}

  <h3>
    <a class="project-link-title" href={projectHref}>{title}</a>
  </h3>

  <p>{summary}</p>

  {visibleTags.length > 0 ? (
    <div class="tag-row">
      {visibleTags.map((tag: string) => <span class="tag">{tag}</span>)}
    </div>
  ) : null}

  <div class="project-actions">
    <a class="btn-primary" href={projectHref}>
      {lang === "fr" ? "Voir le projet" : "View project"}
    </a>

    {project.links?.repo ? (
      <a class="btn-secondary" href={project.links.repo} target="_blank" rel="noreferrer">
        GitHub
      </a>
    ) : null}
  </div>
</article>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .project-company-badge {
    margin-bottom: 0.7rem;
  }

  .project-company-badge img {
    display: block;
    height: var(--company-logo-height, 16px);
    width: auto;
    object-fit: contain;
  }

  .project-actions {
    margin-top: auto;
    padding-top: 1.25rem;
  }
</style>
