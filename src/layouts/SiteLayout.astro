---
import "../styles/global.css";
import LangSwitch from "../components/LangSwitch.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import type { Lang } from "../i18n/config";

type LayoutProps = {
  lang?: Lang;
  title?: string;
  description?: string;
};

const {
  lang = "en",
  title = "Achraf Bahich",
  description = "Data engineering, data science, and applied AI portfolio",
} = Astro.props as LayoutProps;

const copy: Record<
  Lang,
  {
    role: string;
    home: string;
    projects: string;
    about: string;
    contact: string;
    footer: string;
  }
> = {
  en: {
    role: "Data Engineer · Data Science & AI",
    home: "Home",
    projects: "Projects",
    about: "About",
    contact: "Contact",
    footer: "Built with Astro | Achraf Bahich © 2026",
  },
  fr: {
    role: "Ingénieur data · Data Science & IA",
    home: "Accueil",
    projects: "Projets",
    about: "À propos",
    contact: "Contact",
    footer: "Construit avec Astro | Achraf Bahich © 2026",
  },
};

const ui = copy[lang];

const currentPath = Astro.url.pathname.replace(/^\/(en|fr)/, "") || "/";
const homeHref = `/${lang}/`;
const projectsHref = `/${lang}/projects/`;
const aboutHref = `/${lang}/about/`;
const contactHref = `/${lang}/contact/`;
---
<html lang={lang} data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f8fafc" />
    <script is:inline>
      (() => {
        const storageKey = "portfolio-theme";
        const root = document.documentElement;
        const meta = document.querySelector('meta[name="theme-color"]');
        const storedTheme = (() => {
          try {
            const value = window.localStorage.getItem(storageKey);
            return value === "light" || value === "dark" ? value : null;
          } catch {
            return null;
          }
        })();
        const resolvedTheme =
          storedTheme ||
          (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");

        root.dataset.theme = resolvedTheme;
        root.style.colorScheme = resolvedTheme;
        root.style.backgroundColor = resolvedTheme === "dark" ? "#030712" : "#f8fafc";

        if (meta) {
          meta.setAttribute("content", resolvedTheme === "dark" ? "#030712" : "#f8fafc");
        }
      })();
    </script>
  </head>
  <body>
    <div class="shell">
      <div class="site-header-wrap">
        <header class="site-header">
          <a class="brand" href={homeHref}>
            <div class="brand-mark">AB</div>
            <div class="brand-copy">
              <p class="brand-title">Achraf Bahich</p>
              <p class="brand-subtitle">{ui.role}</p>
            </div>
          </a>

          <nav class="site-nav">
            <a class={`nav-link ${currentPath === "/" ? "active" : ""}`} href={homeHref}>
              {ui.home}
            </a>
            <a
              class={`nav-link ${currentPath.startsWith("/projects") ? "active" : ""}`}
              href={projectsHref}
            >
              {ui.projects}
            </a>
            <a class={`nav-link ${currentPath.startsWith("/about") ? "active" : ""}`} href={aboutHref}>
              {ui.about}
            </a>
            <a class={`nav-link ${currentPath.startsWith("/contact") ? "active" : ""}`} href={contactHref}>
              {ui.contact}
            </a>
          </nav>

          <div class="nav-actions">
            <ThemeToggle lang={lang} />
            <LangSwitch lang={lang} path={currentPath} />
          </div>
        </header>
      </div>

      <main class="page-main">
        <slot />
      </main>

      <footer class="site-footer">
        <div class="footer-card">
          {ui.footer}
        </div>
      </footer>
    </div>
  </body>
</html>
