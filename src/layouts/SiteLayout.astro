---
import "../styles/global.css";
import LangSwitch from "../components/LangSwitch.astro";
import type { Lang } from "../i18n/config";

type LayoutProps = {
  lang?: Lang;
  title?: string;
  description?: string;
};

const {
  lang = "en",
  title = "Achraf Bahich",
  description = "Data Engineering and AI portfolio",
} = Astro.props as LayoutProps;

const copy: Record<
  Lang,
  {
    role: string;
    home: string;
    projects: string;
    about: string;
    contact: string;
    footer: string;
  }
> = {
  en: {
    role: "Engineering student · Data & AI",
    home: "Home",
    projects: "Projects",
    about: "About",
    contact: "Contact / Links",
    footer: "Built with Astro · bilingual portfolio focused on Data Engineering and Applied AI",
  },
  fr: {
    role: "Élève ingénieur · Data & IA",
    home: "Accueil",
    projects: "Projets",
    about: "À propos",
    contact: "Contact / Liens",
    footer: "Construit avec Astro · portfolio bilingue orienté Data Engineering et IA appliquée",
  },
};

const ui = copy[lang];

const currentPath = Astro.url.pathname.replace(/^\/(en|fr)/, "") || "/";
const homeHref = `/${lang}/`;
const projectsHref = `/${lang}/projects/`;
const aboutHref = `/${lang}/about/`;
const contactHref = `/${lang}/contact/`;
---
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f8fafc" />
  </head>
  <body>
    <div class="shell">
      <div class="site-header-wrap">
        <header class="site-header">
          <a class="brand" href={homeHref}>
            <div class="brand-mark">AB</div>
            <div class="brand-copy">
              <p class="brand-title">Achraf Bahich</p>
              <p class="brand-subtitle">{ui.role}</p>
            </div>
          </a>

          <nav class="site-nav">
            <a class={`nav-link ${currentPath === "/" ? "active" : ""}`} href={homeHref}>
              {ui.home}
            </a>
            <a
              class={`nav-link ${currentPath.startsWith("/projects") ? "active" : ""}`}
              href={projectsHref}
            >
              {ui.projects}
            </a>
            <a class={`nav-link ${currentPath.startsWith("/about") ? "active" : ""}`} href={aboutHref}>
              {ui.about}
            </a>
            <a class={`nav-link ${currentPath.startsWith("/contact") ? "active" : ""}`} href={contactHref}>
              {ui.contact}
            </a>
          </nav>

          <div class="nav-actions">
            <LangSwitch lang={lang} path={currentPath} />
          </div>
        </header>
      </div>

      <main class="page-main">
        <slot />
      </main>

      <footer class="site-footer">
        <div class="footer-card">
          {ui.footer}
        </div>
      </footer>
    </div>
  </body>
</html>
