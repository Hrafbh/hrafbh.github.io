---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { allLangs as LANGS, isLang, type Lang } from "../../i18n/config";
import { allSkills } from "../../data/skills.js";

type SkillItem = {
  name: string;
  src: string;
};

export function getStaticPaths() {
  return LANGS.map((lang) => ({
    params: { lang },
  }));
}

const { lang: rawLang } = Astro.params;
const lang = (isLang(rawLang ?? "") ? rawLang : "en") as Lang;

const copy = {
  en: {
    title: "About",
    eyebrow: "Profile",
    intro:
      "Data engineer and data scientist with hands-on experience in cloud pipelines, ETL/ELT, analytics, and applied AI. I like turning business needs into reliable data flows, clear technical decisions, and solutions that are genuinely useful to teams.",
    block1Title: "What I work on",
    block1Text:
      "My core focus is data engineering: ingestion, transformation, modeling, orchestration, and data delivery. I also work on machine learning, NLP, and RAG when they solve a concrete operational problem.",
    block2Title: "How I approach projects",
    block2Text:
      "I start from the business need, translate it into flows and transformation rules, then build with readability, maintainability, and delivery in mind. Clear communication with stakeholders is part of the work, not an extra.",
    block3Title: "Recent experience",
    block3Text:
      "At Energy Pool, I automated KPI calculations and contributed to an AI support agent. At Framatome, I built Azure pipelines for GDPR-compliant anonymization. At ERASME, I worked on an NLP solution for information extraction.",
  },
  fr: {
    title: "À propos",
    eyebrow: "Profil",
    intro:
      "Ingénieur spécialisé en Data Engineering et Data Science, avec une expérience concrète sur les pipelines cloud, l'ETL/ELT, l'analytics et l'IA appliquée. J'aime transformer un besoin métier en flux de données fiables, en choix techniques clairs et en solutions vraiment utiles aux équipes.",
    block1Title: "Mes sujets de travail",
    block1Text:
      "Mon axe principal est le data engineering : ingestion, transformation, modélisation, orchestration et mise à disposition de données. Je travaille aussi sur le machine learning, le NLP et le RAG quand ils répondent à un usage métier concret.",
    block2Title: "Ma façon de travailler",
    block2Text:
      "Je pars du besoin opérationnel, je le traduis en flux et en règles de traitement, puis je construis avec un souci de lisibilité, de maintenabilité et de livraison. La communication avec les parties prenantes fait partie du travail.",
    block3Title: "Expériences récentes",
    block3Text:
      "Chez Energy Pool, j'ai automatisé le calcul de KPI et contribué à un agent IA pour le support. Chez Framatome, j'ai développé des pipelines Azure d'anonymisation conformes RGPD. Chez ERASME, j'ai travaillé sur une solution NLP d'extraction d'informations.",
  },
} as const;

const ui = copy[lang];
const typedSkills = allSkills as SkillItem[];
---
<SiteLayout lang={lang} title={`${ui.title} - Achraf Bahich`} description={ui.intro}>
  <section class="page-hero about-hero">
    <div class="about-copy">
      <span class="eyebrow">{ui.eyebrow}</span>
      <h1>{ui.title}</h1>
      <p>{ui.intro}</p>
    </div>

    <ul
      class="about-skills"
      aria-label={lang === "fr" ? "Technologies principales" : "Core technologies"}
    >
      {
        typedSkills.map((skill) => (
          <li class="about-skill-chip" title={skill.name}>
            <img src={skill.src} alt={skill.name} loading="lazy" width="44" height="44" />
          </li>
        ))
      }
    </ul>
  </section>

  <section class="section">
    <div class="focus-grid">
      <article class="focus-card">
        <h3>{ui.block1Title}</h3>
        <p>{ui.block1Text}</p>
      </article>
      <article class="focus-card">
        <h3>{ui.block2Title}</h3>
        <p>{ui.block2Text}</p>
      </article>
      <article class="focus-card">
        <h3>{ui.block3Title}</h3>
        <p>{ui.block3Text}</p>
      </article>
    </div>
  </section>
</SiteLayout>

<style>
  .about-hero {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 28px;
    flex-wrap: nowrap;
  }

  .about-copy {
    flex: 1 1 0;
    min-width: 0;
  }

  .about-skills {
    display: grid;
    grid-template-columns: repeat(3, 88px);
    flex: 0 0 auto;
    gap: 12px;
    margin: 0;
    padding: 0;
    list-style: none;
    width: max-content;
  }

  .about-skill-chip {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 88px;
    height: 88px;
    padding: 8px;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--surface-strong);
  }

  .about-skill-chip img {
    width: 82%;
    height: 82%;
    object-fit: contain;
  }

  @media (max-width: 640px) {
    .about-hero {
      display: grid;
      grid-template-columns: 1fr;
    }

    .about-skills {
      flex: initial;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      width: 100%;
    }

    .about-skill-chip {
      width: 100%;
      height: 74px;
    }
  }
</style>
