---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { allLangs as LANGS, isLang, type Lang } from "../../i18n/config";

export function getStaticPaths() {
  return LANGS.map((lang) => ({
    params: { lang },
  }));
}

const { lang: rawLang } = Astro.params;
const lang = (isLang(rawLang ?? "") ? rawLang : "en") as Lang;

const copy = {
  en: {
    title: "Resume",
    eyebrow: "Professional snapshot",
    intro:
      "A dedicated page for profile highlights, key strengths, and the future downloadable resume link.",
    summaryTitle: "What belongs here",
    summaryItems: [
      "Short profile summary and positioning",
      "Experience or internship highlights",
      "Core technical stack and delivery strengths",
      "Download link to the final CV PDF when ready",
    ],
    noteTitle: "Current state",
    noteText:
      "The page structure is ready even if the final PDF resume has not been added to the repository yet.",
  },
  fr: {
    title: "CV",
    eyebrow: "Vue d'ensemble professionnelle",
    intro:
      "Une page dédiée aux points forts du profil, aux éléments clés du parcours et au futur lien de téléchargement du CV.",
    summaryTitle: "Contenu prévu ici",
    summaryItems: [
      "Résumé du profil et positionnement",
      "Éléments marquants d'expérience ou de stage",
      "Stack technique principale et forces de delivery",
      "Lien de téléchargement vers le CV PDF final quand il sera prêt",
    ],
    noteTitle: "État actuel",
    noteText:
      "La structure de la page est prête même si le PDF final du CV n'est pas encore présent dans le dépôt.",
  },
} as const;

const ui = copy[lang];
---
<SiteLayout lang={lang} title={`${ui.title} - Achraf Bahich`} description={ui.intro}>
  <section class="page-hero">
    <span class="eyebrow">{ui.eyebrow}</span>
    <h1>{ui.title}</h1>
    <p>{ui.intro}</p>
  </section>

  <section class="detail-grid">
    <div>
      <article class="detail-panel">
        <h2>{ui.summaryTitle}</h2>
        <ul>
          {ui.summaryItems.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </div>
    <aside>
      <article class="detail-panel">
        <h3>{ui.noteTitle}</h3>
        <p>{ui.noteText}</p>
      </article>
    </aside>
  </section>
</SiteLayout>
