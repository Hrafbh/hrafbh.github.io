---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { allLangs as LANGS, isLang, type Lang } from "../../i18n/config";

export function getStaticPaths() {
  return LANGS.map((lang) => ({
    params: { lang },
  }));
}

const { lang: rawLang } = Astro.params;
const lang = (isLang(rawLang ?? "") ? rawLang : "en") as Lang;

const contacts = {
  email: "achrafbahich01@gmail.com",
  phoneDisplay: "07 01 21 25 54",
  phoneHref: "tel:0701212554",
  linkedin: "https://linkedin.com/in/achrafbahich/",
  github: "https://github.com/Hrafbh",
} as const;

const copy = {
  en: {
    title: "Contact",
    eyebrow: "Professional contact",
    intro:
      "These are the contact details used on my CV for data engineering, data science, and applied AI opportunities.",
    emailTitle: "Email",
    phoneTitle: "Phone",
    emailText: "Direct channel for opportunities, collaboration, and technical discussions.",
    phoneText: "Quickest way to reach me for a first exchange or an interview.",
    linkedinTitle: "LinkedIn",
    linkedinText: "Professional profile, background, and networking entry point.",
    githubTitle: "GitHub",
    githubText: "Repositories and public project work.",
  },
  fr: {
    title: "Contact",
    eyebrow: "Coordonnées professionnelles",
    intro:
      "Voici les coordonnées présentes sur mes CV pour échanger autour d'opportunités en data engineering, data science et IA appliquée.",
    emailTitle: "Email",
    phoneTitle: "Téléphone",
    emailText: "Canal direct pour les opportunités, les collaborations et les échanges techniques.",
    phoneText: "Le moyen le plus rapide pour un premier échange ou un entretien.",
    linkedinTitle: "LinkedIn",
    linkedinText: "Profil professionnel, parcours et point d'entrée réseau.",
    githubTitle: "GitHub",
    githubText: "Dépôts de code et projets publics.",
  },
} as const;

const ui = copy[lang];
---
<SiteLayout lang={lang} title={`${ui.title} - Achraf Bahich`} description={ui.intro}>
  <section class="page-hero">
    <span class="eyebrow">{ui.eyebrow}</span>
    <h1>{ui.title}</h1>
    <p>{ui.intro}</p>
  </section>

  <section class="section">
    <div class="focus-grid">
      <article class="focus-card">
        <h3>{ui.emailTitle}</h3>
        <p>{ui.emailText}</p>
        <div class="hero-actions">
          <a class="btn-primary" href={`mailto:${contacts.email}`}>
            {contacts.email}
          </a>
        </div>
      </article>
      <article class="focus-card">
        <h3>{ui.phoneTitle}</h3>
        <p>{ui.phoneText}</p>
        <div class="hero-actions">
          <a class="btn-primary" href={contacts.phoneHref}>
            {contacts.phoneDisplay}
          </a>
        </div>
      </article>
      <article class="focus-card">
        <h3>{ui.linkedinTitle}</h3>
        <p>{ui.linkedinText}</p>
        <div class="hero-actions">
          <a class="btn-primary" href={contacts.linkedin} target="_blank" rel="noreferrer">
            linkedin.com/in/achrafbahich
          </a>
        </div>
      </article>
      <article class="focus-card">
        <h3>{ui.githubTitle}</h3>
        <p>{ui.githubText}</p>
        <div class="hero-actions">
          <a class="btn-primary" href={contacts.github} target="_blank" rel="noreferrer">
            github.com/Hrafbh
          </a>
        </div>
      </article>
    </div>
  </section>
</SiteLayout>
