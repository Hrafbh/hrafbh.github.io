---
import SiteLayout from "../../../layouts/SiteLayout.astro";
import ProjectCard from "../../../components/ProjectCard.astro";
import { allLangs as LANGS, isLang, type Lang } from "../../../i18n/config";
import { projects } from "../../../data/projects.js";

export function getStaticPaths() {
  return LANGS.map((lang) => ({
    params: { lang },
  }));
}

const { lang: rawLang } = Astro.params;
const lang = (isLang(rawLang ?? "") ? rawLang : "en") as Lang;

const copy = {
  en: {
    title: "Project portfolio",
    subtitle:
      "The project section now follows the portfolio structure you defined, with the current five entries already in place.",
  },
  fr: {
    title: "Portfolio de projets",
    subtitle:
      "La section projets suit maintenant la structure du portfolio que tu as définie, avec les cinq entrées déjà en place.",
  },
} as const;

const ui = copy[lang];
---
<SiteLayout
  lang={lang}
  title={`Achraf Bahich - ${ui.title}`}
  description={ui.subtitle}
>
  <section class="page-hero">
    <span class="eyebrow">
      {lang === "fr" ? "Sélection de projets" : "Project selection"}
    </span>
    <h1>{ui.title}</h1>
    <p>{ui.subtitle}</p>
  </section>

  <section class="section">
    <div class="project-grid">
      {projects.map((project) => <ProjectCard project={project} lang={lang} />)}
    </div>
  </section>
</SiteLayout>
